rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== VOCABULARY =====
    // Tất cả user đăng nhập đều được ĐỌC, chỉ Admin SDK mới được GHI
    match /vocabulary/{wordId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ===== USER DATA =====
    // Mỗi user chỉ được đọc/ghi data của chính mình
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Progress sub-collection (bao gồm cả "stats" document)
      match /progress/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // FCM tokens — chỉ owner được đọc/ghi
      match /fcmTokens/{tokenId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ===== LEADERBOARD =====
    // Cho phép đọc leaderboard công khai (đã denormalize), chỉ admin ghi
    match /leaderboard/{userId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
